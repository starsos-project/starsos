{
  "name": "starsos-monorepo",
  "version": "0.1.0-alpha.1",
  "private": true,
  "description": "Stars OS — operator layer for AI-native work",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "cd packages/cli && bunx tsup",
    "test": "cd packages/cli && bun test",
    "lint": "bunx biome check packages/cli/src",
    "lint:fix": "bunx biome check --write packages/cli/src",
    "format": "bunx biome format --write packages/cli/src",
    "typecheck": "cd packages/cli && bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
